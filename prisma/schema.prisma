generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Role {
  ADMIN
  FINANCEIRO
  COMERCIAL
  OPERACAO
  GESTOR
}

enum CampaignStatus {
  RASCUNHO
  ATIVA
  PAUSADA
  ENCERRADA
  CANCELADA
}

enum ClientType {
  NOVO
  CASA
}

enum PaymentStatus {
  PENDENTE
  PARCIAL
  PAGO
  CANCELADO
  VENCIDO
}

enum InvoiceStatus {
  EMITIDA
  ENVIADA
  PAGA
  CANCELADA
  VENCIDA
}

enum ReimbursementStatus {
  ENVIADO
  EM_ANALISE
  APROVADO_PARCIAL
  APROVADO
  REJEITADO
  PAGO
}

enum ReimbursementCategory {
  ALIMENTACAO
  TRANSPORTE
  HOSPEDAGEM
  PEDAGIO
  QUILOMETRAGEM
  OUTROS
}

enum CommissionStatus {
  CALCULADA
  APROVADA
  PAGA
  CANCELADA
}

enum CommissionBasis {
  VALOR_VENDIDO
  MARGEM
}

enum ClosingStatus {
  ABERTO
  CONCILIADO
  FECHADO
  DIVERGENTE
}

enum InfluencerPaymentStatus {
  PENDENTE
  PARCIAL
  PAGO
}

enum ClosingEntryType {
  ENTRADA
  SAIDA
}

// ==================== MODELS ====================

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  password  String
  role      Role      @default(COMERCIAL)
  active    Boolean   @default(true)
  avatar    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  auditLogs      AuditLog[]
  sessions       Session[]
  weeklyClosings WeeklyClosing[] @relation("ClosedByUser")
  employees      Employee[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model Client {
  id        String    @id @default(cuid())
  name      String
  tradeName String?
  document  String    @unique
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  notes     String?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  campaigns   Campaign[]
  receivables Receivable[]

  @@map("clients")
}

model Employee {
  id         String    @id @default(cuid())
  name       String
  email      String    @unique
  phone      String?
  position   String?
  department String?
  role       Role
  active     Boolean   @default(true)
  userId     String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  user                  User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  campaignsAsExecutive  Campaign[]      @relation("CampaignExecutive")
  campaignsAsOperation  Campaign[]      @relation("CampaignOperation")
  reimbursements        Reimbursement[]
  commissions           Commission[]

  @@index([userId])
  @@map("employees")
}

model CostCenter {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaigns      Campaign[]
  reimbursements Reimbursement[]

  @@map("cost_centers")
}

model Campaign {
  id           String         @id @default(cuid())
  name         String
  description  String?
  clientId     String
  clientType   ClientType     @default(NOVO)
  executiveId  String
  operationId  String
  costCenterId String
  startDate    DateTime
  endDate      DateTime
  soldValue    Decimal        @db.Decimal(12, 2)
  status       CampaignStatus @default(RASCUNHO)
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  client       Client               @relation(fields: [clientId], references: [id])
  executive    Employee             @relation("CampaignExecutive", fields: [executiveId], references: [id])
  operation    Employee             @relation("CampaignOperation", fields: [operationId], references: [id])
  costCenter   CostCenter           @relation(fields: [costCenterId], references: [id])
  influencers  CampaignInfluencer[]
  receivables  Receivable[]
  reimbursements Reimbursement[]
  commissions  Commission[]

  @@index([clientId])
  @@index([executiveId])
  @@index([operationId])
  @@index([status])
  @@map("campaigns")
}

model CampaignInfluencer {
  id              String                  @id @default(cuid())
  campaignId      String
  name            String
  socialHandle    String?
  negotiatedValue Decimal                 @db.Decimal(12, 2)
  negotiationDate DateTime?
  paymentDeadline DateTime?
  dueDate         DateTime?
  paidValue       Decimal                 @default(0) @db.Decimal(12, 2)
  openValue       Decimal                 @default(0) @db.Decimal(12, 2)
  status          InfluencerPaymentStatus @default(PENDENTE)
  notes           String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  deletedAt       DateTime?

  campaign Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  payments InfluencerPayment[]

  @@index([campaignId])
  @@map("campaign_influencers")
}

model InfluencerPayment {
  id                    String   @id @default(cuid())
  campaignInfluencerId  String
  value                 Decimal  @db.Decimal(12, 2)
  paymentDate           DateTime
  method                String?
  receipt               String?
  notes                 String?
  createdAt             DateTime @default(now())

  campaignInfluencer CampaignInfluencer @relation(fields: [campaignInfluencerId], references: [id], onDelete: Cascade)

  @@index([campaignInfluencerId])
  @@map("influencer_payments")
}

model Receivable {
  id                String        @id @default(cuid())
  campaignId        String
  clientId          String
  invoiceNumber     String?
  issueDate         DateTime?
  value             Decimal       @db.Decimal(12, 2)
  dueDate           DateTime
  installment       Int           @default(1)
  totalInstallments Int           @default(1)
  status            InvoiceStatus @default(EMITIDA)
  receivedDate      DateTime?
  receivedValue     Decimal?      @db.Decimal(12, 2)
  paymentMethod     String?
  receipt           String?
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id])

  @@index([campaignId])
  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  @@map("receivables")
}

model Reimbursement {
  id             String                @id @default(cuid())
  employeeId     String
  campaignId     String?
  costCenterId   String
  category       ReimbursementCategory
  requestedValue Decimal               @db.Decimal(12, 2)
  approvedValue  Decimal?              @db.Decimal(12, 2)
  paidValue      Decimal               @default(0) @db.Decimal(12, 2)
  date           DateTime
  description    String
  receipt        String?
  status         ReimbursementStatus   @default(ENVIADO)
  reviewNotes    String?
  paidDate       DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  deletedAt      DateTime?

  employee   Employee    @relation(fields: [employeeId], references: [id])
  campaign   Campaign?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  costCenter CostCenter  @relation(fields: [costCenterId], references: [id])

  @@index([employeeId])
  @@index([campaignId])
  @@index([status])
  @@map("reimbursements")
}

model ReimbursementRule {
  id             String                @id @default(cuid())
  category       ReimbursementCategory @unique
  maxValuePerDay Decimal               @db.Decimal(12, 2)
  description    String?
  active         Boolean               @default(true)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@map("reimbursement_rules")
}

model CommissionRule {
  id          String          @id @default(cuid())
  role        Role
  clientType  ClientType
  basis       CommissionBasis
  percentage  Decimal         @db.Decimal(5, 2)
  active      Boolean         @default(true)
  validFrom   DateTime?
  validUntil  DateTime?
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  commissions Commission[]

  @@map("commission_rules")
}

model Commission {
  id              String           @id @default(cuid())
  campaignId      String
  employeeId      String
  ruleId          String
  basis           CommissionBasis
  baseValue       Decimal          @db.Decimal(12, 2)
  percentage      Decimal          @db.Decimal(5, 2)
  calculatedValue Decimal          @db.Decimal(12, 2)
  status          CommissionStatus @default(CALCULADA)
  frozen          Boolean          @default(false)
  paidValue       Decimal          @default(0) @db.Decimal(12, 2)
  paidDate        DateTime?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  campaign Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  employee Employee       @relation(fields: [employeeId], references: [id])
  rule     CommissionRule @relation(fields: [ruleId], references: [id])

  @@index([campaignId])
  @@index([employeeId])
  @@index([status])
  @@map("commissions")
}

model WeeklyClosing {
  id              String        @id @default(cuid())
  weekStart       DateTime
  weekEnd         DateTime
  openingBalance  Decimal       @db.Decimal(12, 2)
  totalIncome     Decimal       @db.Decimal(12, 2)
  totalExpenses   Decimal       @db.Decimal(12, 2)
  expectedBalance Decimal       @db.Decimal(12, 2)
  actualBalance   Decimal       @db.Decimal(12, 2)
  difference      Decimal       @db.Decimal(12, 2)
  justification   String?
  status          ClosingStatus @default(ABERTO)
  closedBy        String?
  closedAt        DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  closedByUser User?               @relation("ClosedByUser", fields: [closedBy], references: [id], onDelete: SetNull)
  entries      WeeklyClosingEntry[]

  @@index([weekStart])
  @@map("weekly_closings")
}

model WeeklyClosingEntry {
  id              String           @id @default(cuid())
  weeklyClosingId String
  type            ClosingEntryType
  description     String
  value           Decimal          @db.Decimal(12, 2)
  category        String?
  reference       String?
  createdAt       DateTime         @default(now())

  weeklyClosing WeeklyClosing @relation(fields: [weeklyClosingId], references: [id], onDelete: Cascade)

  @@index([weeklyClosingId])
  @@map("weekly_closing_entries")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
