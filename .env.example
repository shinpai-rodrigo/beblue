# BeBlue - Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env or .env.production to version control

DATABASE_URL=postgresql://beblue:YOUR_STRONG_PASSWORD@localhost:5432/beblue
JWT_SECRET=YOUR_RANDOM_SECRET_MIN_64_CHARS
NEXT_PUBLIC_APP_NAME=BeBlue
NEXT_PUBLIC_APP_URL=https://beblue.shinp.ai
NODE_ENV=development
SEED_ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD
